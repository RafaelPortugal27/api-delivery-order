# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://snack_user:snack_pass@localhost:5432/snack_db?schema=public"
DB_USER=snack_user
DB_PASSWORD=snack_pass
DB_NAME=snack_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# OTP
OTP_EXPIRES_IN_MINUTES=10

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM="Snack App <your@email.com>"

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+5511999999999
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Evolution API (WhatsApp alternative - self-hosted)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE=snack_instance
